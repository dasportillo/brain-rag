{
  "name": "brain-rag",
  "version": "0.1.0",
  "description": "Local, private RAG second brain over your Claude Code transcripts, served back to Claude Code as an MCP server.",
  "type": "module",
  "bin": {
    "brain-rag": "./cli.mjs"
  },
  "files": [
    "cli.mjs",
    "install.mjs",
    "uninstall.mjs",
    "server.mjs",
    "store.mjs",
    "embed.mjs",
    "ingest.mjs",
    "import.mjs",
    "forget.mjs",
    "transcripts.mjs",
    "search.mjs",
    "state.mjs",
    "mark-keep.mjs",
    "mark-current-keep.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "ingest": "node ingest.mjs",
    "search": "node search.mjs",
    "stats": "node ingest.mjs --stats",
    "serve": "node server.mjs",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dasportillo/brain-rag.git"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "rag",
    "second-brain",
    "embeddings",
    "transformers.js"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.3.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  }
}
